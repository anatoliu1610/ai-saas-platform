{
  "name": "ai-saas-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=web",
    "build": "turbo build --filter=web",
    "lint": "turbo lint --filter=web",
    "test": "turbo test --filter=web",
    "db:generate": "pnpm --filter=web db:generate",
    "db:push": "pnpm --filter=web db:push",
    "docker:build": "docker build -t ai-saas-web .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
