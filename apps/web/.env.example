# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_saas"

# Auth (REQUIRED - must be set in production)
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# Redis (for rate limiting)
REDIS_URL="redis://localhost:6379"

# AI Configuration (choose one or both)
# Priority: OpenAI > Ollama
OPENAI_API_KEY="sk-..."           # Get from https://platform.openai.com/api-keys
OPENAI_MODEL="gpt-4o-mini"       # Optional: default model

OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"           # Optional: default model

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
